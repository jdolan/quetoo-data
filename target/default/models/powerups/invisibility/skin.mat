{
	diffusemap powerups/invisibility/skin
	normalmap powerups/invisibility/skin_norm
	specularmap powerups/invisibility/skin_spec
	roughness 1.0
	hardness 1.0
	specularity 1.0
	{
		envmap envmaps/gold
		blend GL_SRC_ALPHA GL_ONE
		color 1 1 1 1
		lighting 1 flat
		scale.s .5
		scale.t .5
		scroll.s .5
		scroll.t .5
		shell 12
	}
}
